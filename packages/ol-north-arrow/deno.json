{
  "name": "@liuxspro/ol-north-arrow",
  "version": "0.1.0",
  "exports": "./src/index.ts",
  "exclude": ["demo"],
  "tasks": {
    "dev": "deno run --watch --allow-net main.ts",
    "build": "deno run -A npm:esbuild src/index.ts --bundle --outfile=dist/north-arrow.js --format=esm --external:ol --external:ol/*",
    "preview": "deno run -A jsr:@std/http@1/file-server ."
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "ol": "npm:ol@^10.9.0"
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom", "dom.iterable"]
  }
}
